{
  "compilerOptions": {
    /* Core */
    "target": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    /* JSX */
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    /* Next.js */
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* Interop */
    "esModuleInterop": true,
    /* Type Safety */
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    /* Absolute imports */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@lib/*": ["./src/lib/*"],
      "@ui/*": ["./src/ui/*"],
      "@forms/*": ["./src/forms/*"],
      "@lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
